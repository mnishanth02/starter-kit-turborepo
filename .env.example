# Shared reference for variables used across the monorepo.
# Runtime loading is split by app:
# - apps/web/.env.local for the Next.js app and mounted API
# - apps/mobile/.env.local for the Expo app
#
# Do not expect Expo or Next.js to load a repo-root .env.local automatically.

# Database (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
TEST_DATABASE_URL=postgresql://user:password@host/dbname_test?sslmode=require

# Clerk Auth
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# CI (optional)
TURBO_TOKEN=
TURBO_TEAM=
CRON_SECRET=replace-with-a-long-random-secret

ALLOW_DB_RESET=false
